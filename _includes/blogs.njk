                    </div>
                  </div>

                  <!-- CTA Section -->
                  <div class="cta-section mt-5 p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 10px; color: white;">
                    <h4>Ready to Transform Your Business with ERPNext?</h4>
                    <p class="mb-3">As the official ERPNext Gold Partner in Dubai, we help businesses streamline operations and drive growth.</p>
                    <a href="/services/erpnext-demo/" class="btn btn-light btn-lg" style="border-radius: 25px;">
                      Book a Free Demo
                    </a>
                  </div>

                </div>
              </div>
            </div>
          </div>
        </section>



      </main>
    </div>
    <!-- [id] content -->
