  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Dynamic Title -->
  {% if title %}
  <title>{{ title }} | ERPNext Dubai - Official Gold Partner UAE</title>
  {% else %}
  <title>ERPNext Dubai - Official ERPNext Gold Partner in UAE, Dubai, Abu Dhabi</title>
  {% endif %}

  <!-- Dynamic Meta Description -->
  {% if intro %}
  <meta name="description" content="{{ intro | stripHtml | truncate(160) }}"/>
  {% else %}
  <meta name="description" content="Official ERPNext Gold Partner in Dubai, UAE. Expert ERPNext implementation, customization, and support for businesses across UAE, Abu Dhabi, and the Middle East."/>
  {% endif %}

  <meta name="keywords" content="ERPNext Dubai, ERPNext UAE, ERP Dubai, ERPNext Partner, ERPNext Implementation, ERPNext Customization, ERP Abu Dhabi, ERPNext Middle East, Open Source ERP, Manufacturing ERP, Accounting Software Dubai"/>
  <meta name="author" content="Craft Interactive - ERPNext Gold Partner UAE"/>

  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"/>

  <!-- Canonical URL -->
  <link rel="canonical" href="https://www.erpnextdubai.com{{ page.url }}"/>

  <!-- Open Graph Tags -->
  <meta property="og:locale" content="en_US"/>
  <meta property="og:type" content="{% if layout == 'blogs.njk' %}article{% else %}website{% endif %}"/>
  <meta property="og:title" content="{{ title | default('ERPNext Dubai - Official Gold Partner UAE') }}"/>
  <meta property="og:description" content="{{ intro | default('Official ERPNext Gold Partner in Dubai, UAE. Expert ERPNext implementation, customization, and support.') | stripHtml | truncate(200) }}"/>
  <meta property="og:url" content="https://www.erpnextdubai.com{{ page.url }}"/>
  <meta property="og:site_name" content="ERPNext Dubai"/>
  {% if image %}
  <meta property="og:image" content="https://www.erpnextdubai.com{{ image }}"/>
  {% else %}
  <meta property="og:image" content="https://www.erpnextdubai.com/assets/img/erpnext-hero-compressed.png"/>
  {% endif %}

  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ title | default('ERPNext Dubai - Official Gold Partner UAE') }}"/>
  <meta name="twitter:description" content="{{ intro | default('Official ERPNext Gold Partner in Dubai, UAE. Expert ERPNext implementation, customization, and support.') | stripHtml | truncate(200) }}"/>
  {% if image %}
  <meta name="twitter:image" content="https://www.erpnextdubai.com{{ image }}"/>
  {% endif %}

  <!-- Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Craft Interactive",
    "alternateName": "ERPNext Dubai",
    "url": "https://www.erpnextdubai.com",
    "logo": "https://www.erpnextdubai.com/assets/img/logo.png",
    "description": "Official ERPNext Gold Partner providing implementation, customization, and support services in Dubai, UAE, and the Middle East.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Dubai",
      "addressCountry": "AE"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+971-56-259-8881",
      "contactType": "sales",
      "availableLanguage": ["English", "Arabic"]
    },
    "sameAs": [
      "https://www.facebook.com/craftinteractive.ae",
      "https://www.linkedin.com/company/craft-interactive-llc",
      "https://twitter.com/craftinteract"
    ]
  }
  </script>

  <!-- LocalBusiness Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "ERPNext Dubai - Craft Interactive",
    "image": "https://www.erpnextdubai.com/assets/img/logo.png",
    "url": "https://www.erpnextdubai.com",
    "telephone": "+971-56-259-8881",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Dubai",
      "addressRegion": "Dubai",
      "addressCountry": "AE"
    },
    "priceRange": "$$",
    "openingHours": "Mo-Fr 09:00-18:00"
  }
  </script>

  <!-- favicon -->
  <link rel="shortcut icon" href="/assets/img/favicon.ico" type="image/x-icon" />
  <!-- Bootstrap 4.5 -->
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css" type="text/css" />
