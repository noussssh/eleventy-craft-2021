---
title: Craft Interactive
layout: base.njk
pagination:
  data: collections.blog
  size: 20
  reverse: true
  alias: posts
---



      <!-- Stat main -->
      <main data-spy="scroll" data-target="#navbar-example2" data-offset="0">

      

        <!-- Start blog_slider -->
        <section class="section__stories blog_slider padding-t-12">
          <div class="container">
            <div class="row justify-content-center">
              <div class="col-lg-12">
                <div class="swip__stories">
                  <!-- Swiper -->
                  <div class="swiper-container blog-slider">
                    <div class="title_sections_inner">
                      <h2>Blogs</h2>
                    </div>
                    
                    
                  </div>

                </div>
              </div>
            </div>

          </div>
        </section>
        <!-- End. blog_slider -->


        <!-- End. dividar_line -->

        <!-- Start blog_inner_list -->
        <section class="blog_inner_list">
          <div class="container">
            <div class="row">
              <div class="col-lg-8 margin-b-12">



                {%- for blog in posts -%} 



                <div class="grid_blog_avatar list_style">
                  <div class="row">
                    <div class="col-md-6">
                      <div class="cover_blog">
                        <img src="{{ blog.data.image }} " alt="{{ blog.data.title}} ">
                      </div>
                    </div>
                    <div class="col-md-6 my-auto">
                      <div class="body_blog">
                        <a href="#">
                          <div class="person media">
                            
                            <div class="media-body">
                              <div class="txt">
                                
                                <time>{{ blog.data.posted | dateFormat }}</time>
                              </div>
                            </div>
                          </div>
                        </a>
                        <a href="{{blog.url}}" class="link_blog">
                          <h4 class="title_blog">
                            {{ blog.data.title }}
                          </h4>
                          <p class="short_desc">
                             {{ blog.data.intro }} 
                          </p>
                        </a>


                      </div>
                    </div>
                  </div>
                </div>
                <!-- End grid_blog_avatar -->

                {%- endfor -%}

                <!-- Pagination Navigation -->
                <nav class="pagination-nav mt-5" aria-label="Blog pagination">
                  <ul class="pagination justify-content-center">
                    {% if pagination.href.previous %}
                      <li class="page-item">
                        <a class="page-link" href="{{ pagination.href.previous }}">← Previous</a>
                      </li>
                    {% endif %}

                    {% for pageEntry in pagination.pages %}
                      <li class="page-item {% if page.url == pagination.hrefs[loop.index0] %}active{% endif %}">
                        <a class="page-link" href="{{ pagination.hrefs[loop.index0] }}">{{ loop.index }}</a>
                      </li>
                    {% endfor %}

                    {% if pagination.href.next %}
                      <li class="page-item">
                        <a class="page-link" href="{{ pagination.href.next }}">Next →</a>
                      </li>
                    {% endif %}
                  </ul>
                </nav>

              </div>
              <div class="col-lg-4 margin-b-5">
                <div class="widgets">
                  
                
                  <div class="quotatio-w">
                    <span>Testimonials</span>
                    <p>It has been a pleasure working with Craft Interactive Team. We utilized their ERPNext skills and expertise, We look forward to many more working opportunities with them.
                    </p>
                    <span class="auther"> Konrad Schwitter </span>
                    <span class="auther"> OfficeOne Stationary and Supplies</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
        <!-- End. blog_inner_list -->

 

      </main>
    </div>
    <!-- [id] content -->
