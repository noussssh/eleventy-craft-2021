<section class="margin-t-5 ">
  <div class="container">
    <h3 class="margin-b-4 text-center">
      Some of our ERPNext customers in the region.
    </h3>
    <div class="row p-5 p-sm-0 justify-content-center">
      {% for customer  in customers %}
        {% if customer.home %}
          <div class="col-6 col-md-4 col-lg-2 mb-5 align-self-center">
            <img width="130" src="/assets/img/customers/{{customer.logo}}" alt="{{customer.name}}" />
          </div>
        {% endif %}
      {% endfor %}     
    </div>
  </div>
</section>










